{
  "name": "gsagents",
  "version": "1.0.0",
  "private": true,
  "description": "gsagents.ai - Production-grade autonomous AI software engineering platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "docker:dev": "docker-compose -f infrastructure/docker/compose/dev.yml up -d",
    "docker:prod": "docker-compose -f infrastructure/docker/compose/prod.yml up -d",
    "web:dev": "pnpm --filter @gsagents/web dev",
    "web:build": "pnpm --filter @gsagents/web build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}